# Copy to e2e/.env for local runs. e2e/.env is ignored by git.

# Local default. Authenticated tests must use an HTTPS *.gainforest.app URL.
E2E_BASE_URL=https://local-e2e.gainforest.app
E2E_PORT=3201
# Required. Use the same auth source as the app; there is no E2E-specific fallback.
NEXT_PUBLIC_AUTH_BASE_URL=

# Optional handle/password login sanity check in auth.setup.
# If omitted, that sanity test is skipped and the suite still uses disposable email auth.
# These values are also used as a static account fallback for direct PDS checks if disposable metadata is absent.
# Keep the password in e2e/.env or your shell, not in source control.
# E2E_TEST_HANDLE=certs-e2e-tester.climateai.org
# E2E_TEST_DID=did:plc:o7yvu2ukphuealyp34pgfalv
# E2E_TEST_PASSWORD=
E2E_TEST_PDS_DOMAIN=dev.certified.app

# Optional disposable email settings. Mail.tm is used by default because the
# group PDS accepts it as a recovery email. E2E teardown always deletes the
# run-owned disposable accounts and CGS group PDS account.
# E2E_DISPOSABLE_EMAIL_PROVIDER=mailtm
# E2E_DISPOSABLE_EMAIL_PREFIX=gf-e2e
# E2E_DISPOSABLE_EMAIL_TIMEOUT_MS=150000

# Optional: run against an already-started app or a preview URL.
# E2E_SKIP_WEB_SERVER=1
# VERCEL_BYPASS_SECRET=
