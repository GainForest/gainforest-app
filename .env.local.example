# GainForest — environment

# Local auth requires a *.gainforest.app origin. Run `pnpm dev` and
# `pnpm dev:proxy`, then open https://local.gainforest.app (Caddy proxies to
# the Next.js dev server on :3040). Set this to the configured central auth
# service origin. The app intentionally has no fallback when this is unset.
NEXT_PUBLIC_AUTH_BASE_URL=
# Hyperindex GraphQL endpoint. Defaults to the production GainForest indexer
# when unset; set this for local/dev indexer testing.
# NEXT_PUBLIC_INDEXER_URL=https://api.hi.gainforest.app/graphql

# Hosted drone/orthophoto/point-cloud viewer embedded under Manage → Drone.
NEXT_PUBLIC_DRONE_APP_URL=https://drone.gainforest.app

# GainForest CGS organization account. Owners and admins of this organization can
# use /internal/badges, and badge records are written to this account.
# NEXT_PUBLIC_GAINFOREST_CGS_ACCOUNT=gainforest-e-v.certified.one

# Named ePDS provider configured by the auth service. GainForest/certs deployments
# must use the certified.one provider instead of the auth service's default ePDS.
NEXT_PUBLIC_AUTH_PROVIDER=certs

# Admin-only AudioMoth spectrogram labelling preview. The UI is additionally
# restricted to GainForest admin-group members. Defaults enabled for admins;
# set to false to remove it for everyone.
AUDIOMOTH_LABELLING_ENABLED=true
# CGS group email invitations. SUPABASE_* stores invitation rows. If this app
# does not use the same Supabase project/service-role key as the auth service,
# set AUTH_INTERNAL_SERVICE_TOKEN to the auth service's internal service token so
# invitation acceptance can add members server-to-server.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# AUTH_INTERNAL_SERVICE_TOKEN=
# RESEND_API_KEY=
# Shared sender for invitation and welcome emails. Make sure the domain is
# verified in Resend before sending to real recipients.
EMAIL_FROM="GainForest <noreply@gainforest.id>"

# Tainá field-Pi liveness (the /devices page). Read-only Healthchecks.io API
# key for the GainForest project that the Raspberry Pis heartbeat to. When
# unset, /devices shows a "monitoring not configured" state instead of failing.
# Get it from healthchecks.io → Project Settings → API Access (read-only key).
# HEALTHCHECKS_API_KEY=

# Single Bumicert donations. The facilitator pays Base gas for EIP-3009 USDC
# authorizations and writes org.hypercerts.funding.receipt records.
# FACILITATOR_SERVICE_HOST=https://bsky.social
# FACILITATOR_PASSWORD=
# FACILITATOR_PRIVATE_KEY=0x...
# BASE_RPC_URL=https://mainnet.base.org
# NEXT_PUBLIC_FACILITATOR_DID=did:plc:edod7rboajioq3jbyxsgeicc

# Owner donation settings (enable & configure donations on a bumicert).
# The facilitator wallet address that signs EVM-link platform attestations;
# a linked wallet is only "trusted" for receiving donations if it matches.
# NEXT_PUBLIC_FACILITATOR_WALLET_ADDRESS=0x...
# WalletConnect Cloud project id — required by RainbowKit for mobile wallets.
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Welcome emails. Auth emits signed lifecycle events to
# /api/internal/welcome-email-events; Bumicerts renders the welcome email and
# sends it through Resend. In auth, set APP_EVENT_WEBHOOK_URL to this route and
# keep APP_EVENT_WEBHOOK_SECRET identical to WELCOME_EMAIL_WEBHOOK_SECRET.
# WELCOME_EMAIL_WEBHOOK_SECRET=
# Temporary/dummy community form URL until the real form is ready. In production,
# the community-network bonus block is omitted unless this is set.
# WELCOME_COMMUNITY_FORM_URL=https://example.com/gainforest-community-network

# Floating Tainá chat companion on /manage/bumicerts/new. Streams replies via
# OpenRouter in the Tainá sim's voice (persona fetched from her PDS). When
# OPENROUTER_API_KEY is unset, the widget still appears but the chat reports
# "not configured" instead of failing.
# OPENROUTER_API_KEY=sk-or-v1-...
# DEFAULT_CHAT_MODEL=google/gemini-2.5-flash

# Observation photo analysis/autofill. Server-side only; add the same key in
# Vercel for production/preview deployments.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# Tainá — the Telegram field assistant (../agent-village). The /taina setup
# page and the profile Tainá tab proxy to this always-on Flue runtime. The
# secret MUST match the runtime's PROVISION_SHARED_SECRET (Railway). Without
# these, Tainá falls back to a local runtime at http://127.0.0.1:3583.
# TAINA_FLUE_BASE_URL="https://agent-village-flue-production.up.railway.app"
# TAINA_PROVISION_SHARED_SECRET=

# AudioMoth firmware list (/audiomoth firmware tab). Optional GitHub token so
# the release-list proxy uses the authenticated API rate limit (5000/hour)
# instead of the shared unauthenticated one (60/hour per IP), which is easily
# exhausted behind serverless egress. A fine-grained token with public read
# access — or a classic token with no scopes — is enough. Firmware downloads
# do not need it. Without a token the roster still works but may intermittently
# show "Couldn't load the release list" when the limit is hit.
# GITHUB_TOKEN=
